{
    "name": "np-config",
    "$schema": "../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "sourceRoot": "libs/np-config/src",
    "prefix": "np-afterwork",
    "targets": {
        "test": {
            "executor": "@nx/vitest:test",
