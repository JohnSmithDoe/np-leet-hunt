{
    "compileOnSave": false,
    "compilerOptions": {
        "rootDir": ".",
        "strict": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "declaration": false,
        "moduleResolution": "bundler",
        "experimentalDecorators": true,
        "importHelpers": true,
        "target": "es2022",
        "module": "esnext",
        "newLine": "lf",
        "lib": ["es2022", "dom"],
        "useDefineForClassFields": false,
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "paths": {
            "@shared/np-audio": ["libs/np-audio/src/index.ts"],
            "@shared/np-config": ["libs/np-config/src/index.ts"],
            "@shared/np-pixel-dungeon": ["libs/np-pixel-dungeon/src/index.ts"],
            "@shared/np-library": ["libs/np-library/src/index.ts"],
            "@shared/np-paradroid": ["libs/np-paradroid/src/index.ts"],
            "@shared/np-phaser": ["libs/np-phaser/src/index.ts"],
            "@shared/np-space-map": ["libs/np-space-map/src/index.ts"],
            "@shared/np-state": ["libs/np-state/src/index.ts"]
        }
    },
    "exclude": ["node_modules", "tmp"]
}
