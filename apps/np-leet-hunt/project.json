{
    "name": "np-leet-hunt",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "sourceRoot": "apps/np-leet-hunt/src",
    "prefix": "np",
    "targets": {
        "build": {
            "executor": "@angular/build:application",
            "outputs": ["{workspaceRoot}/dist/apps/np-leet-hunt"],
            "options": {
                "outputPath": {
                    "base": "dist/apps/np-leet-hunt",
                    "browser": ""
                },
                "index": "apps/np-leet-hunt/src/index.html",
                "browser": "apps/np-leet-hunt/src/main.ts",
                "tsConfig": "apps/np-leet-hunt/tsconfig.app.json",
                "inlineStyleLanguage": "scss",
                "assets": [
                    "apps/np-leet-hunt/src/assets",
                    {
                        "glob": "**/*.svg",
                        "input": "node_modules/ionicons/dist/ionicons/svg",
                        "output": "./svg"
                    },
                    {
                        "glob": "**/assets/**/*",
                        "input": "libs/np-phaser/src/lib/sprites",
                        "output": "./np-phaser"
                    },
                    {
                        "glob": "**/*",
                        "input": "libs/np-paradroid/src/assets",
                        "output": "./np-paradroid"
                    },
                    {
                        "glob": "**/*",
                        "input": "libs/np-space-map/src/assets",
                        "output": "./np-space-map"
                    },
                    {
                        "glob": "**/*",
                        "input": "libs/np-pixel-dungeon/src/assets",
                        "output": "./np-pixel-dungeon"
                    },
                    {
                        "glob": "**/*",
                        "input": "libs/np-audio/src/lib/assets",
                        "output": "./np-audio"
                    }
                ],
                "styles": ["apps/np-leet-hunt/src/global.scss"],
                "scripts": [],
                "allowedCommonJsDependencies": ["phaser", "poisson-disk-sampling", "eventemitter3"]
            },
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "4mb",
                            "maximumError": "6mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "2kb",
                            "maximumError": "4kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "apps/np-leet-hunt/src/environments/environment.ts",
                            "with": "apps/np-leet-hunt/src/environments/environment.prod.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "optimization": false,
                    "extractLicenses": false,
                    "sourceMap": true
                }
            },
            "defaultConfiguration": "production"
        },
        "serve": {
            "executor": "@angular/build:dev-server",
            "configurations": {
                "production": {
                    "buildTarget": "np-leet-hunt:build:production"
                },
                "development": {
                    "buildTarget": "np-leet-hunt:build:development"
                }
            },
            "defaultConfiguration": "development"
        },
        "extract-i18n": {
            "executor": "@angular/build:extract-i18n",
            "options": {
                "buildTarget": "np-leet-hunt:build"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "test": {
            "executor": "@nx/vitest:test",
            "outputs": ["{options.reportsDirectory}"],
            "options": {
                "configFile": "apps/np-leet-hunt/vitest.config.ts",
                "reportsDirectory": "../../coverage/apps/np-leet-hunt"
            }
        },
        "stylelint": {
            "executor": "nx-stylelint:lint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["apps/np-leet-hunt/**/*.css", "apps/np-leet-hunt/**/*.scss"]
            }
        }
    },
    "tags": []
}
