{
    "name": "np-leet-hunt",
    "version": "1.0.0",
    "license": "MIT",
    "scripts": {
        "start": "nx serve",
        "build": "nx build --base-href ./",
        "test": "nx run-many -t test --no-tui",
        "e2e": "nx e2e np-leet-hunt-e2e",
        "prepare": "husky",
        "serve:app:angular": "nx serve np-leet-hunt",
        "build:app:angular": "nx build np-leet-hunt",
        "copy:app:angular": "cd apps/np-leet-hunt && npx cap copy",
        "sync:app:angular": "cd apps/np-leet-hunt && npx cap sync",
        "update:app:angular": "cd apps/np-leet-hunt && npx cap update",
        "ios:app:angular": "cd apps/np-leet-hunt && npx cap open ios",
        "android:app:angular": "cd apps/np-leet-hunt && npx cap open android"
    },
    "private": true,
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "dependencies": {
        "@angular/animations": "21.2.17",
        "@angular/common": "21.2.17",
        "@angular/compiler": "21.2.17",
        "@angular/core": "21.2.17",
        "@angular/forms": "21.2.17",
        "@angular/platform-browser": "21.2.17",
        "@angular/platform-browser-dynamic": "21.2.17",
        "@angular/router": "21.2.17",
        "@capacitor/app": "^8.1.0",
        "@capacitor/core": "^8.4.0",
        "@capacitor/haptics": "^8.0.2",
        "@capacitor/keyboard": "^8.0.3",
        "@capacitor/preferences": "^8.0.1",
        "@capacitor/status-bar": "^8.0.2",
        "@ionic/angular": "^8.8.10",
        "phaser": "^3.90.0",
        "phaser3-rex-plugins": "^1.80.20",
        "poisson-disk-sampling": "^2.3.1",
        "rxjs": "~7.8.2",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@analogjs/vite-plugin-angular": "^2.6.1",
        "@angular/build": "~21.2.15",
        "@angular/cli": "~21.2.0",
        "@angular/compiler-cli": "21.2.17",
        "@angular/language-service": "21.2.17",
        "@capacitor/cli": "^8.4.0",
        "@ionic/angular-toolkit": "^12.3.0",
        "@nx/angular": "22.7.5",
        "@nx/devkit": "22.7.5",
        "@nx/eslint": "22.7.5",
        "@nx/playwright": "22.7.5",
        "@nx/vite": "22.7.5",
        "@nx/vitest": "^22.7.5",
        "@nx/workspace": "22.7.5",
        "@playwright/test": "^1.60.0",
        "@types/node": "^22.19.21",
        "@types/poisson-disk-sampling": "^2.2.4",
        "@vitest/coverage-v8": "^4.1.8",
        "angular-eslint": "^21.4.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "license-checker": "^25.0.1",
        "lint-staged": "^17.0.7",
        "nx": "22.7.5",
        "nx-stylelint": "^19.0.0",
        "phaser3spectorjs": "^0.0.8",
        "prettier": "^3.8.4",
        "sass": "^1.101.0",
        "stylelint": "^17.13.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vitest": "^4.1.8",
        "vitest-canvas-mock": "^1.1.4"
    },
    "lint-staged": {
        "*.{js,ts,html}": [
            "eslint --fix"
        ],
        "*.{css,scss}": [
            "stylelint --fix"
        ]
    }
}
