{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "master",
    "defaultProject": "np-leet-hunt",
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "sharedGlobals": [
            "{workspaceRoot}/.stylelintrc.json",
            "{workspaceRoot}/tsconfig.base.json",
            "{workspaceRoot}/tsconfig.json"
        ],
        "production": [
            "default",
            "!{projectRoot}/eslint.config.mjs",
            "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
            "!{projectRoot}/tsconfig.spec.json",
            "!{projectRoot}/vitest.config.[jt]s",
            "!{projectRoot}/.stylelintrc(.(json|yml|yaml|js))?"
        ]
    },
    "targetDefaults": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["production", "^production"],
            "cache": true
        },
        "lint": {
            "inputs": ["default", "{workspaceRoot}/eslint.config.mjs"],
            "cache": true
        },
        "test": {
            "inputs": ["default", "^production"],
            "cache": true
        },
        "e2e": {
            "inputs": ["default", "^production"],
            "cache": true
        },
        "stylelint": {
            "inputs": [
                "default",
                "{workspaceRoot}/.stylelintrc.json",
                "{workspaceRoot}/.stylelintrc(.(json|yml|yaml|js))?"
            ],
            "cache": true
        }
    },
    "generators": {
        "@nx/angular:application": {
            "style": "scss",
            "linter": "eslint",
            "unitTestRunner": "vitest-analog",
            "e2eTestRunner": "playwright"
        },
        "@nx/angular:library": {
            "linter": "eslint",
            "unitTestRunner": "vitest-analog"
        },
        "@nx/angular:component": {
            "style": "scss"
        }
    },
    "analytics": false
}
